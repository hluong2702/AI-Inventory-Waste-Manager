VITE_API_BASE_URL=http://localhost:8080/api
VITE_PAYMENT_PROVIDER=PAYOS
VITE_PAYMENT_METHOD=BANK_TRANSFER
BUSINESS_TIME_ZONE=Asia/Ho_Chi_Minh
DB_URL=jdbc:mysql://database.example.com:3306/inventory_ai?useSSL=true&requireSSL=true&verifyServerCertificate=true&serverTimezone=UTC
DB_USERNAME=inventory_ai_app
DB_PASSWORD=
REDIS_URL=rediss://default:password@redis.example.com:6379
# Use a different namespace for every deployment environment sharing a Redis cluster.
CACHE_NAMESPACE=inventoryai:production:v3
SUBSCRIPTION_CACHE_TTL=5m
JWT_ISSUER=inventoryai.vn
JWT_AUDIENCE=inventoryai-api
# Generate a unique high-entropy secret (at least 32 bytes); never reuse this example file as a secret.
JWT_SECRET=
CORS_ALLOWED_ORIGINS=https://app.example.com
FRONTEND_LOGIN_URL=https://app.example.com/login
FRONTEND_INVITE_URL=https://app.example.com/accept-invite
# Comma-separated CIDRs of the ingress/load balancer directly trusted to set Forwarded/X-Forwarded-For.
# Leave empty when the application is directly internet-facing.
TRUSTED_PROXY_CIDRS=10.0.0.0/8
CLIENT_IP_MAX_HEADER_LENGTH=4096
CLIENT_IP_MAX_HOPS=16
AUTH_REFRESH_COOKIE_NAME=inventoryai_refresh
AUTH_REFRESH_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_SAME_SITE=Lax
# Leave blank for a safer host-only cookie; set only when a shared parent domain is strictly required.
AUTH_REFRESH_COOKIE_DOMAIN=
# Tune these after observing legitimate traffic; defaults are intentionally conservative.
AUTH_RATE_LOGIN_IP_MAX=50
AUTH_RATE_LOGIN_ACCOUNT_MAX=20
AUTH_RATE_LOGIN_PAIR_MAX=8
AUTH_RATE_REGISTER_IP_MAX=10
AUTH_RATE_REGISTER_EMAIL_MAX=3
AUTH_RATE_REFRESH_IP_MAX=120
AUTH_RATE_REFRESH_SESSION_MAX=20

PAYOS_ENABLED=true
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
PAYOS_RETURN_URL=https://your-app.example.com/billing?payment=success
PAYOS_CANCEL_URL=https://your-app.example.com/billing?payment=failed
PAYOS_EXPIRE_MINUTES=15

# Spring Boot backend mail config
INVITATION_EMAIL_ENABLED=true
MAIL_USERNAME=your-gmail-address@gmail.com
MAIL_APP_PASSWORD=your-16-character-gmail-app-password
