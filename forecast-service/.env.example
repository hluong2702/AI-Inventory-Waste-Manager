# forecast-service/.env.example
# Copy sang .env và điều chỉnh theo môi trường

# Port mà FastAPI lắng nghe
PORT=8001

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Cho phép CORS từ Spring Boot backend
ALLOWED_ORIGINS=http://localhost:8080

# Số worker processes (1 là đủ cho dev, 2-4 cho production)
WORKERS=1

# Bật auto-reload khi dev (không dùng trong production)
RELOAD=false
